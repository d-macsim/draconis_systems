---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/format";

const updates = (await getCollection("updates")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout
  title="Updates | Draconis Systems"
  description="Operational updates, build logs, and inventory notices from Draconis Systems."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Updates" }]}
>
  <section class="section">
    <div class="container stack">
      <p class="eyebrow">What Is Going On</p>
      <h1>Updates</h1>
      <p>Latest queue windows, build methodology notes, and component availability updates.</p>

      <div class="grid grid-2">
        {updates.map((entry) => (
          <article class="card stack" style="gap:0.75rem;">
            <p class="badge">{entry.data.category}</p>
            <h2 style="font-size:1.4rem;margin:0;">{entry.data.title}</h2>
            <p>{entry.data.summary}</p>
            <p class="small">{formatDate(entry.data.date)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

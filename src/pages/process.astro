---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BuildJourney from "@/components/process/BuildJourney";
import queueStatusData from "@/data/queue-status.json";
import workshopStagesData from "@/data/workshop-stages.json";
import type { QueueStatus, WorkshopStage } from "@/lib/types";

const queueStatus = queueStatusData as QueueStatus;
const workshopStages = workshopStagesData as WorkshopStage[];
---
<BaseLayout
  title="Process | Draconis Systems"
  description="Explore the boutique Draconis build journey from curation to white-glove hand-off."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Process" }]}
>
  <section class="section">
    <div class="container stack">
      <p class="eyebrow">Commission Journey</p>
      <h1>From Curation to Hand-off</h1>
      <p>
        Every Draconis system moves through a defined boutique workflow focused on visual finish, thermal stability,
        and dependable long-session performance.
      </p>

      <BuildJourney client:visible stages={workshopStages} queueStatus={queueStatus} />
    </div>
  </section>
</BaseLayout>

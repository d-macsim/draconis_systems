---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout
  title="Warranty | Draconis Systems"
  description="Warranty coverage overview and support boundaries for Draconis Systems services."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Warranty" }]}
>
  <section class="section">
    <div class="container card stack">
      <h1>Warranty Overview</h1>
      <p>
        Warranty terms vary by service package and component sourcing model. Final coverage details are confirmed in
        your signed quote and service agreement.
      </p>

      <h2>Baseline Coverage</h2>
      <ul class="clean stack">
        <li>Assembly workmanship: 1 year from delivery date</li>
        <li>Remote diagnostics: included for 12 months</li>
        <li>Manufacturer RMA coordination guidance: available on request</li>
      </ul>

      <h2>Exclusions</h2>
      <p>
        Coverage does not include damage from misuse, liquid ingress, unauthorised hardware modification,
        or software-level corruption unrelated to delivered configuration.
      </p>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ConfiguratorApp from "@/components/configurator/ConfiguratorApp";
import BuildQuestionnaire from "@/components/configurator/BuildQuestionnaire";
import catalog from "@/data/configurator/components.json";
import rules from "@/data/configurator/rules.json";
import type { ComponentCatalog, ConfiguratorRules } from "@/lib/types";

const typedCatalog = catalog as ComponentCatalog;
const typedRules = rules as ConfiguratorRules;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  applicationCategory: "BusinessApplication",
  name: "Draconis Systems Configurator",
  operatingSystem: "Any",
  description:
    "Guided custom PC configurator with compatibility checks, estimated price ranges, and quote export."
};
---
<BaseLayout
  title="Custom Configurator | Draconis Systems"
  description="Build a guided custom PC estimate with compatibility checks and export to quote request."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Configurator" }]}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <section class="section">
    <div class="container stack">
      <p class="eyebrow">Guided Estimator</p>
      <h1>Custom PC Configurator</h1>
      <p>
        Build your system in steps, check core compatibility, and export your selection to a quote request.
        Estimates are non-binding and finalized during sourcing.
      </p>

      <details class="surface" style="padding: 1rem">
        <summary style="cursor: pointer; font-weight: 700; color: var(--text)">
          Not sure what to choose? Open the quick questionnaire for a full preconfigured recommendation.
        </summary>
        <div style="margin-top: 1rem">
          <BuildQuestionnaire client:visible catalog={typedCatalog} rules={typedRules} />
        </div>
      </details>

      <div id="configurator-builder" class="stack" style="gap: 0.35rem">
        <h2 style="margin-bottom: 0">Build It Manually</h2>
        <p class="small" style="margin: 0">
          Prefer direct control? Use the full step-by-step configurator.
        </p>
      </div>

      <ConfiguratorApp client:visible catalog={typedCatalog} rules={typedRules} />
    </div>
  </section>
</BaseLayout>

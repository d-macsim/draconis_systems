---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ConfiguratorApp from "@/components/configurator/ConfiguratorApp";
import UseCaseTiles from "@/components/UseCaseTiles.astro";
import catalog from "@/data/configurator/components.json";
import queueStatusData from "@/data/queue-status.json";
import rules from "@/data/configurator/rules.json";
import type { ComponentCatalog, ConfiguratorRules, QueueStatus } from "@/lib/types";

const typedCatalog = catalog as ComponentCatalog;
const typedRules = rules as ConfiguratorRules;
const queueStatus = queueStatusData as QueueStatus;

function tierToProfile(tier: string): string {
  return tier === "entry" || tier === "mid" ? "profile-mid-range" : "profile-high-end";
}

const startingPointsRaw = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const startingPoints = startingPointsRaw.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  cpu: p.data.cpu,
  gpu: p.data.gpu,
  useCase: p.data.useCase,
  budgetTier: p.data.budgetTier,
  profile: tierToProfile(p.data.budgetTier),
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  applicationCategory: "BusinessApplication",
  name: "Draconis Systems Configurator",
  operatingSystem: "Any",
  description:
    "Guided custom PC configurator with compatibility checks, estimated price ranges, and quote export."
};
---
<BaseLayout
  title="Custom Configurator | Draconis Systems"
  description="Build a guided custom PC estimate with compatibility checks and export to quote request."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Configurator" }]}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <!-- ── Page header ── -->
  <header class="config-header">
    <div class="container config-header__inner">
      <div class="config-header__copy">
        <p class="eyebrow">Guided Estimator</p>
        <h1 class="config-header__title">Build your<br /><em>system.</em></h1>
        <p class="config-header__sub">
          Describe your workload, pick your tier, and export a quote.
          Every build ships with a 1-year assembly warranty, 24-hr stress validation,
          and complete handoff documentation.
        </p>
      </div>
      <ul class="clean config-header__trust">
        <li class="trust-pill">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.4" fill="none"/>
            <path d="M3.5 6l2 2L8.5 4" stroke="currentColor" stroke-width="1.4"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          1-year assembly warranty
        </li>
        <li class="trust-pill">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.4" fill="none"/>
            <path d="M3.5 6l2 2L8.5 4" stroke="currentColor" stroke-width="1.4"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          24-hr stress validation
        </li>
        <li class="trust-pill">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.4" fill="none"/>
            <path d="M3.5 6l2 2L8.5 4" stroke="currentColor" stroke-width="1.4"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          UK-based studio
        </li>
      </ul>
    </div>
  </header>

  <!-- ── Launch zone: use-case tiles + starting points ── -->
  <section class="config-launch">
    <div class="container">

      <p class="eyebrow">Start by use case</p>
      <UseCaseTiles />

      {startingPoints.length > 0 && (
        <div class="starting-points">
          <div class="starting-points__rule">
            <span class="starting-points__rule-label">Or jump from a real build</span>
          </div>
          <div class="starting-points__grid">
            {startingPoints.map((project) => (
              <a
                href={`/configurator?profile=${project.profile}`}
                class="starting-point-card"
                title={`Configure a system similar to ${project.title}`}
              >
                <div class="starting-point-card__meta">
                  <span class="badge">{project.useCase}</span>
                  <span class="badge">{project.budgetTier}</span>
                </div>
                <strong class="starting-point-card__name">{project.title}</strong>
                {(project.cpu || project.gpu) && (
                  <dl class="starting-point-specs">
                    {project.cpu && <><dt>CPU</dt><dd>{project.cpu}</dd></>}
                    {project.gpu && <><dt>GPU</dt><dd>{project.gpu}</dd></>}
                  </dl>
                )}
                <span class="starting-point-card__cta">
                  Build Similar
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6h8M6.5 2.5l3.5 3.5-3.5 3.5" stroke="currentColor"
                      stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <!-- ── Builder divider ── -->
  <div class="builder-divider" aria-hidden="true">
    <div class="container builder-divider__inner">
      <span class="builder-divider__label">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
          <rect x="8" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
          <rect x="1" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
          <rect x="8" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
        </svg>
        Configure step-by-step
      </span>
    </div>
  </div>

  <!-- ── Builder ── -->
  <section class="section">
    <div class="container">
      <ConfiguratorApp
        client:visible
        catalog={typedCatalog}
        rules={typedRules}
        showQuestionnaire={true}
        queueStatus={queueStatus}
      />
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page header ── */
  .config-header {
    border-bottom: 1px solid var(--line);
    background: var(--bg-soft);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .config-header__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .config-header__copy {
    max-width: 52ch;
  }

  .config-header__title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .config-header__title em {
    font-style: italic;
    color: var(--brand);
  }

  .config-header__sub {
    font-size: clamp(0.9rem, 1.4vw, 1rem);
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0;
    max-width: 48ch;
  }

  .config-header__trust {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-self: flex-end;
    flex-shrink: 0;
  }

  .trust-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .trust-pill svg {
    color: var(--ok);
    flex-shrink: 0;
  }

  /* ── Launch zone ── */
  .config-launch {
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .config-launch .eyebrow {
    margin-bottom: 1.25rem;
  }

  /* ── Starting points ── */
  .starting-points {
    margin-top: 2rem;
  }

  .starting-points__rule {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .starting-points__rule::before,
  .starting-points__rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .starting-points__rule-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .starting-points__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.75rem;
  }

  .starting-point-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.1rem 1.25rem;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color 220ms ease, box-shadow 220ms ease;
  }

  .starting-point-card:hover {
    border-color: color-mix(in srgb, var(--brand) 38%, var(--line));
    box-shadow: var(--shadow-md);
  }

  .starting-point-card:hover .starting-point-card__cta {
    gap: 0.6rem;
  }

  .starting-point-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .starting-point-card__name {
    font-size: 0.88rem;
    color: var(--text);
    line-height: 1.3;
  }

  .starting-point-specs {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr;
    column-gap: 0.4rem;
    row-gap: 0.15rem;
    align-items: baseline;
    margin: 0;
  }

  .starting-point-specs dt {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .starting-point-specs dd {
    margin: 0;
    font-size: 0.75rem;
    color: var(--text-soft);
  }

  .starting-point-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--brand);
    margin-top: 0.2rem;
    transition: gap 180ms ease;
  }

  /* ── Builder divider ── */
  .builder-divider {
    border-block: 1px solid var(--line);
    background: var(--bg-soft);
    padding-block: 0.75rem;
  }

  .builder-divider__inner {
    display: flex;
    align-items: center;
  }

  .builder-divider__label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
  }

  .builder-divider__label svg {
    color: var(--brand);
    opacity: 0.7;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .config-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .config-header__trust {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  }
</style>

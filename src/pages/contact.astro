---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---
<BaseLayout
  title="Contact | Draconis Systems"
  description="Send a general inquiry or quote request to Draconis Systems."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
>
  {turnstileSiteKey && <script defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>}
  <section class="section">
    <div class="container grid grid-2" style="align-items:start;">
      <section class="stack">
        <p class="eyebrow">Get In Touch</p>
        <h1>Contact and quote requests</h1>
        <p>
          Use this form for custom build inquiries, upgrade consulting, and workstation planning. Include your target
          software, preferred timeline, and budget range for the fastest quote turnaround.
        </p>
        <div class="card small">
          <p><strong>Email:</strong> sales@draconis-systems.example</p>
          <p><strong>Service region:</strong> United States (phase 1)</p>
          <p><strong>Typical response time:</strong> within 1 business day</p>
        </div>
      </section>

      <ContactForm client:visible turnstileSiteKey={turnstileSiteKey} />
    </div>
  </section>
</BaseLayout>

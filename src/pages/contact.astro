---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---
<BaseLayout
  title="Contact | Draconis Systems"
  description="Start a bespoke build discussion with the Draconis concierge team."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
>
  {turnstileSiteKey && <script defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>}
  <section class="section">
    <div class="container grid grid-2" style="align-items:start;">
      <section class="stack">
        <p class="eyebrow">Concierge Desk</p>
        <h1>Bespoke enquiries and quotes</h1>
        <p>
          Use this form for custom commissions, upgrade planning, and studio/workstation consultation. Share your
          preferred timeline, budget band, and visual direction for faster scoping.
        </p>
        <div class="card small">
          <p><strong>Email:</strong> concierge@draconis-systems.co.uk</p>
          <p><strong>Service region:</strong> United Kingdom</p>
          <p><strong>Typical response time:</strong> within 1 working day</p>
        </div>
      </section>

      <ContactForm client:visible turnstileSiteKey={turnstileSiteKey} />
    </div>
  </section>
</BaseLayout>

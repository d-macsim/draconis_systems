---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---
{items.length > 0 && (
  <nav aria-label="Breadcrumb" class="container" style="padding-top:1rem;">
    <ol class="clean row small" style="gap:0.5rem;">
      {items.map((item, index) => (
        <li>
          {index > 0 && <span aria-hidden="true">/</span>}
          {item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
        </li>
      ))}
    </ol>
  </nav>
)}

<section class="social-proof" aria-label="Client testimonials">
  <div class="container social-proof__inner">

    <div class="social-proof__hd reveal-on-scroll">
      <span class="eyebrow">Trusted by</span>
      <h2 class="social-proof__title">Clients who<br /><em>demanded more.</em></h2>
    </div>

    <div class="social-proof__quotes">

      <!-- TODO: replace with real client quotes -->
      <blockquote class="quote-card reveal-on-scroll delay-1">
        <p class="quote-card__text">
          "The thermal performance blew away every off-the-shelf system I'd previously used. Frame pacing is rock solid across 6+ hours of continuous sessions."
        </p>
        <footer class="quote-card__footer">
          <span class="quote-card__use-case">Competitive Esports Rig</span>
        </footer>
      </blockquote>

      <!-- TODO: replace with real client quote -->
      <blockquote class="quote-card reveal-on-scroll delay-2">
        <p class="quote-card__text">
          "Render times dropped by nearly 40% versus my previous build. The documentation made it easy to hand off to my editor too."
        </p>
        <footer class="quote-card__footer">
          <span class="quote-card__use-case">Video Production Workstation</span>
        </footer>
      </blockquote>

      <!-- TODO: replace with real client quote -->
      <blockquote class="quote-card reveal-on-scroll delay-3">
        <p class="quote-card__text">
          "Zero guesswork on specs — every component choice was explained. The cable management is genuinely impressive for a studio environment."
        </p>
        <footer class="quote-card__footer">
          <span class="quote-card__use-case">Professional CAD Station</span>
        </footer>
      </blockquote>

    </div>

  </div>
</section>

<style>
  .social-proof {
    border-block: 1px solid var(--line);
    background: var(--bg-soft);
    padding-block: clamp(3rem, 6vw, 5rem);
    overflow: hidden;
  }

  .social-proof__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .social-proof__hd {
    position: sticky;
    top: 5rem;
  }

  .social-proof__title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--text);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  .social-proof__title em {
    font-style: italic;
    color: var(--brand);
  }

  /* ── Quote cards ── */
  .social-proof__quotes {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quote-card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl, 1rem);
    padding: 1.5rem;
    margin: 0;
    transition: border-color 250ms ease;
  }

  .quote-card:hover {
    border-color: color-mix(in srgb, var(--brand) 30%, var(--line));
  }

  .quote-card__text {
    font-size: 0.92rem;
    font-style: italic;
    color: var(--text-soft);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .quote-card__text::before {
    content: '\201C';
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.25em;
    color: var(--brand);
    margin-right: 0.1em;
    opacity: 0.6;
  }

  .quote-card__footer {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .quote-card__use-case {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 999px;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .social-proof__inner {
      grid-template-columns: 1fr;
    }

    .social-proof__hd {
      position: static;
    }
  }
</style>

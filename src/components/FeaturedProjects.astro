---
import type { ProjectEntry } from "@/lib/types";

interface Props {
  projects: ProjectEntry[];
}

const { projects } = Astro.props;
---

<section class="projects-section section-xl" id="featured-projects">
  <div class="container">

    <header class="projects-hd reveal-on-scroll">
      <div>
        <span class="eyebrow">Featured Projects</span>
        <h2 class="projects-hd__title">Recent systems<br /><em>shipped.</em></h2>
      </div>
      <a href="/projects" class="button secondary projects-hd__cta">
        Browse all projects
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2 6.5h9M7.5 3l3.5 3.5L7.5 10" stroke="currentColor" stroke-width="1.7"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </header>

    <div class="projects-list">
      {projects.map((project, i) => (
        <article class={`project-row reveal-on-scroll delay-${Math.min(i + 1, 3)}`}>

          <a href={`/projects/${project.slug}`} class="project-row__img-link" tabindex="-1" aria-hidden="true">
            <div class="project-row__img-wrap">
              <img
                src={project.heroImage}
                alt={project.title}
                width="800"
                height="500"
                loading="lazy"
                class="project-row__img"
              />
              <div class="project-row__img-overlay"></div>
            </div>
          </a>

          <div class="project-row__body">
            <div class="project-row__meta">
              <span class="badge">{project.useCase}</span>
              <span class="badge">{project.budgetTier}</span>
            </div>
            <h3 class="project-row__title">
              <a href={`/projects/${project.slug}`}>{project.title}</a>
            </h3>
            <p class="project-row__summary">{project.summary}</p>

            {(project.cpu || project.gpu) && (
              <dl class="project-specs">
                {project.cpu && <><dt>CPU</dt><dd>{project.cpu}</dd></>}
                {project.gpu && <><dt>GPU</dt><dd>{project.gpu}</dd></>}
              </dl>
            )}

            <a href={`/projects/${project.slug}`} class="project-cta-link">
              View build details
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .projects-section { overflow: hidden; }

  /* ── Header ── */
  .projects-hd {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .projects-hd__title {
    font-size: clamp(2.2rem, 5.5vw, 4.2rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 0;
    color: var(--text);
  }

  .projects-hd__title em { font-style: italic; color: var(--brand); }

  .projects-hd__cta {
    font-size: 0.85rem;
    padding: 0.65rem 1.2rem;
    gap: 0.45rem;
    white-space: nowrap;
    align-self: flex-end;
  }

  /* ── Project rows ── */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .project-row {
    display: grid;
    grid-template-columns: 42% 58%;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    min-height: 360px;
    transition: border-color 320ms ease, box-shadow 320ms ease;
  }

  /* Alternate: even rows flip image to right */
  .project-row:nth-child(even) { direction: rtl; }
  .project-row:nth-child(even) > * { direction: ltr; }

  .project-row:hover {
    border-color: color-mix(in srgb, var(--brand) 40%, var(--line));
    box-shadow: var(--shadow-lg), var(--glow-sm);
  }

  /* ── Image ── */
  .project-row__img-link {
    display: block;
    overflow: hidden;
  }

  .project-row__img-wrap {
    position: relative;
    height: 100%;
    min-height: 320px;
    overflow: hidden;
  }

  .project-row__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-row:hover .project-row__img { transform: scale(1.05); }

  .project-row__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 55%,
      color-mix(in srgb, var(--bg-elev) 40%, transparent) 100%
    );
    pointer-events: none;
  }

  .project-row:nth-child(even) .project-row__img-overlay {
    background: linear-gradient(
      to left,
      transparent 55%,
      color-mix(in srgb, var(--bg-elev) 40%, transparent) 100%
    );
  }

  /* ── Content ── */
  .project-row__body {
    padding: clamp(1.75rem, 3.5vw, 3rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
  }

  .project-row__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .project-row__title {
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .project-row__title a {
    color: inherit;
    text-decoration: none;
    transition: color 200ms ease;
  }

  .project-row__title a:hover { color: var(--brand); }

  .project-row__summary {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    max-width: 44ch;
  }

  /* Spec table */
  .project-specs {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr;
    column-gap: 0.5rem;
    row-gap: 0.3rem;
    margin: 0 0 1.25rem;
    align-items: center;
  }

  .project-specs dt {
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .project-specs dd {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-soft);
  }

  .project-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.83rem;
    font-weight: 700;
    color: var(--brand);
    text-decoration: none;
    margin-top: auto;
    transition: gap 220ms ease;
  }

  .project-cta-link svg { transition: transform 220ms ease; }
  .project-cta-link:hover { gap: 0.75rem; }
  .project-cta-link:hover svg { transform: translateX(3px); }

  /* ── Responsive ── */
  @media (max-width: 820px) {
    .project-row {
      grid-template-columns: 1fr;
      direction: ltr !important;
    }

    .project-row > * { direction: ltr !important; }

    .project-row__img-wrap {
      min-height: 220px;
      max-height: 260px;
    }

    .project-row__img-overlay {
      background: linear-gradient(
        to bottom,
        transparent 50%,
        color-mix(in srgb, var(--bg-elev) 40%, transparent) 100%
      ) !important;
    }

    .projects-hd {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
